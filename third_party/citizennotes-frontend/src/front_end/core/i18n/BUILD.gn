import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")
import("../../../scripts/build/ninja/citizennotes_pre_built.gni")
import("../../../scripts/build/ninja/node.gni")

import("//$citizennotes_root_location/config/gni/i18n.gni")

citizennotes_module("i18n") {
  sources = [
    "CitizenNotesLocale.ts",
    "i18nImpl.ts",
    "i18nTypes.ts",
    "time-utilities.ts",
  ]

  deps = [
    ":locales_js",
    "../../core/platform:bundle",
    "../../core/root:bundle",
    "../../third_party/i18n:bundle",
    "../../third_party/intl-messageformat:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "i18n.ts"
  deps = [ ":i18n" ]

  visibility = [ "*" ]
}

node_action("generate_locales_js") {
  script = "front_end/core/i18n/generate-locales-js.js"

  args = [
    "--target-gen-dir",
    rebase_path(target_gen_dir, root_build_dir),
  ]
  args += [ "--remote-locales" ]
  args += remote_citizennotes_locales

  args += [ "--bundled-locales" ]
  args += bundled_citizennotes_locales

  args += [
    "--default-locale",
    citizennotes_default_locale,
  ]

  args += [
    "--remote-fetch-pattern",
    remote_fetch_pattern,
  ]

  args += [
    "--local-fetch-pattern",
    local_fetch_pattern,
  ]

  outputs = [ "$target_gen_dir/locales.js" ]
  data = outputs

  if (is_debug) {
    metadata = {
      grd_files = outputs
    }
  }
}

citizennotes_pre_built("locales_js") {
  sources = [
    "locales.d.ts",
    "locales_js-tsconfig.json",
  ]

  deps = [ ":generate_locales_js" ]
}
