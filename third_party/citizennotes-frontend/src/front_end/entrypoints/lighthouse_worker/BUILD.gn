import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")

citizennotes_module("lighthouse_worker") {
  sources = [ "LighthouseWorkerService.ts" ]

  deps = [
    "../../core/root:bundle",
    "../../core/sdk:bundle",
    "../../services/puppeteer:bundle",
    "../../third_party/lighthouse",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "lighthouse_worker.ts"

  is_web_worker = true

  deps = [ ":lighthouse_worker" ]

  visibility = [ "../..:front_end" ]
}
