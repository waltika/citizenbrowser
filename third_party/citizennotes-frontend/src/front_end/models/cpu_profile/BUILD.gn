import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")

citizennotes_module("cpu_profile") {
  sources = [
    "CPUProfileDataModel.ts",
    "ProfileTreeModel.ts",
  ]

  deps = [
    "../../core/common:bundle",
    "../../core/platform:bundle",
    "../../generated",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "cpu_profile.ts"

  deps = [ ":cpu_profile" ]

  visibility = [
    ":*",
    "../../../test/unittests/*",
    "../../core/sdk/*",
    "../../panels/profiler/*",
    "../../panels/timeline/*",
    "../../ui/legacy/components/perf_ui/*",
    "../timeline_model/*",
    "../trace/*",
  ]
}
