import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")
import("../visibility.gni")

citizennotes_module("emulation") {
  sources = [
    "DeviceModeModel.ts",
    "EmulatedDevices.ts",
  ]

  deps = [
    "../../core/common:bundle",
    "../../core/host:bundle",
    "../../core/i18n:bundle",
    "../../core/platform:bundle",
    "../../core/root:bundle",
    "../../core/sdk:bundle",
    "../../generated:protocol",
    "../../ui/legacy:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "emulation.ts"

  deps = [ ":emulation" ]

  visibility = [
    ":*",
    "../../../test/unittests/front_end/entrypoints/missing_entrypoints/*",
    "../../../test/unittests/front_end/models/emulation/*",
    "../../panels/emulation/*",
  ]

  visibility += citizennotes_models_visibility
}
