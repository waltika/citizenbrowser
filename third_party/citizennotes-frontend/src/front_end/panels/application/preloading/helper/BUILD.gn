import("../../../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../../../scripts/build/ninja/citizennotes_module.gni")
import("../../../visibility.gni")

citizennotes_module("helper") {
  sources = [ "PreloadingForward.ts" ]

  deps = [ "../../../../core/sdk:bundle" ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "helper.ts"

  deps = [ ":helper" ]

  visibility = [
    ":*",
    "../:*",
    "../../:*",
    "../../../../ui/components/docs/*",
    "../components:*",
  ]

  visibility += citizennotes_panels_visibility
}
