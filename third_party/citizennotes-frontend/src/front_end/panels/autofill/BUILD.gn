import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")
import("../../../scripts/build/ninja/generate_css.gni")
import("../visibility.gni")

generate_css("css_files") {
  sources = [ "autofillView.css" ]
}

citizennotes_module("autofill") {
  sources = [ "AutofillView.ts" ]

  deps = [
    "../../core/i18n:bundle",
    "../../core/platform:bundle",
    "../../core/sdk:bundle",
    "../../ui/components/data_grid:bundle",
    "../../ui/components/legacy_wrapper:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "autofill.ts"

  deps = [
    ":autofill",
    ":css_files",
  ]

  visibility = [
    ":*",
    "../../../test/unittests/front_end/panels/autofill/*",
    "../../entrypoints/*",
  ]

  visibility += citizennotes_panels_visibility
}

citizennotes_entrypoint("meta") {
  entrypoint = "autofill-meta.ts"

  deps = [ ":bundle" ]

  visibility = [ "../../entrypoints/*" ]
}
