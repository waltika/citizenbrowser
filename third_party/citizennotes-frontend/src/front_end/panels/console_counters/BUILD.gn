import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")
import("../visibility.gni")

citizennotes_module("console_counters") {
  sources = [ "WarningErrorCounter.ts" ]

  deps = [
    "../../core/common:bundle",
    "../../core/host:bundle",
    "../../core/i18n:bundle",
    "../../core/root:bundle",
    "../../core/sdk:bundle",
    "../../models/issues_manager:bundle",
    "../../ui/components/helpers:bundle",
    "../../ui/components/icon_button:bundle",
    "../../ui/components/issue_counter:bundle",
    "../../ui/legacy:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "console_counters.ts"

  deps = [ ":console_counters" ]

  visibility = [
    ":*",
    "../../../test/unittests/front_end/entrypoints/missing_entrypoints/*",
    "../../entrypoints/*",
    "../../legacy_test_runner/*",
    "../../ui/components/docs/issue_counter/*",

    # TODO(crbug.com/1202788): Remove invalid dependents
    "../console/*",
    "../issues/*",
    "../sources/*",
  ]

  visibility += citizennotes_panels_visibility
}

citizennotes_entrypoint("meta") {
  entrypoint = "console_counters-meta.ts"

  deps = [ ":bundle" ]

  visibility = [ "../../entrypoints/*" ]
}
