import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")
import("../../../scripts/build/ninja/generate_css.gni")
import("../visibility.gni")

generate_css("css_files") {
  sources = [
    "./components/consoleInsight.css",
    "./components/consoleInsightSourcesList.css",
  ]
}

citizennotes_module("explain") {
  sources = [
    "ActionDelegate.ts",
    "InsightProvider.ts",
    "PromptBuilder.ts",
    "components/ConsoleInsight.ts",
  ]

  deps = [
    ":css_files",
    "../../core/host:bundle",
    "../../models/logs:bundle",
    "../../third_party/marked:bundle",
    "../../ui/components/markdown_view:bundle",
    "../../ui/legacy:bundle",
    "../../ui/legacy/components/source_frame:bundle",
    "../console:bundle",
    "../test:bundle",
    "../sources:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "explain.ts"

  deps = [ ":explain" ]

  visibility = [
    ":*",
    "../../../test/interactions/*",
    "../../../test/unittests/*",
    "../../../test/unittests/front_end/panels/emulation/*",
    "../../entrypoints/*",
    "../../legacy_test_runner/*",
    "../../ui/components/docs/console_insight/*",
  ]

  visibility += citizennotes_panels_visibility
}

citizennotes_entrypoint("meta") {
  entrypoint = "explain-meta.ts"

  deps = [
    ":bundle",
    "../../core/i18n:bundle",
    "../../models/workspace:bundle",
    "../../ui/legacy:bundle",
    "../console:bundle",
    "../test:bundle",
    "../sources:bundle",
  ]

  visibility = [ "../../entrypoints/*" ]
}
