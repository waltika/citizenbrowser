import("../../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../../scripts/build/ninja/citizennotes_module.gni")
import("../../../../scripts/build/ninja/generate_css.gni")
import("../../visibility.gni")

generate_css("css_files") {
  sources = [ "devicesSettingsTab.css" ]
}

citizennotes_module("emulation") {
  sources = [ "DevicesSettingsTab.ts" ]

  deps = [
    "../../../core/i18n:bundle",
    "../../../ui/legacy:bundle",
    "../../emulation:bundle",
    "./components:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "emulation.ts"

  deps = [
    ":css_files",
    ":emulation",
  ]

  visibility = [
    ":*",
    "../../../../test/unittests/front_end/entrypoints/missing_entrypoints/*",
    "../../../../test/unittests/front_end/panels/settings/emulation/*",
    "../../../entrypoints/*",
  ]

  visibility += citizennotes_panels_visibility
}

citizennotes_entrypoint("meta") {
  entrypoint = "emulation-meta.ts"

  deps = [ ":bundle" ]

  visibility = [
    "../*",
    "../../../entrypoints/*",
  ]
}
