import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")
import("../../../scripts/build/ninja/generate_css.gni")
import("../visibility.gni")

generate_css("css_files") {
  sources = [
    "testContextSelector.css",
    "testPinPane.css",
    "testPrompt.css",
    "testSidebar.css",
    "testView.css",
  ]
}

citizennotes_module("test") {
  sources = [
    "TestContextSelector.ts",
    "TestFilter.ts",
    "TestFormat.ts",
    "TestPanel.ts",
    "TestPinPane.ts",
    "TestPrompt.ts",
    "TestSidebar.ts",
    "TestView.ts",
    "TestViewMessage.ts",
    "TestViewport.ts",
    "TSErrorStackParser.ts",
  ]

  deps = [
    "../../../extension-api",
    "../../core/common:bundle",
    "../../core/host:bundle",
    "../../core/i18n:bundle",
    "../../core/platform:bundle",
    "../../core/sdk:bundle",
    "../../models/bindings:bundle",
    "../../models/issues_manager:bundle",
    "../../models/logs:bundle",
    "../../models/source_map_scopes:bundle",
    "../../models/text_utils:bundle",
    "../../third_party/codemirror.next:bundle",
    "../../ui/components/code_highlighter:bundle",
    "../../ui/components/icon_button:bundle",
    "../../ui/components/request_link_icon:bundle",
    "../../ui/components/text_editor:bundle",
    "../../ui/legacy:bundle",
    "../../ui/legacy/components/data_grid:bundle",
    "../../ui/legacy/components/object_ui:bundle",
    "../../ui/legacy/components/utils:bundle",
    "../../ui/legacy/theme_support:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "test.ts"

  deps = [
    ":test",
    ":css_files",
    "../../ui/legacy/components/object_ui:css_files",
  ]

  visibility = [
    ":*",
    "../../../test/e2e/test/*",
    "../../../test/unittests/front_end/entrypoints/missing_entrypoints/*",
    "../../../test/unittests/front_end/panels/test/*",
    "../../entrypoints/*",
    "../../panels/explain/*",
  ]

  visibility += citizennotes_panels_visibility
}

citizennotes_entrypoint("meta") {
  entrypoint = "test-meta.ts"

  deps = [ ":bundle" ]

  visibility = [ "../../entrypoints/*" ]
}
