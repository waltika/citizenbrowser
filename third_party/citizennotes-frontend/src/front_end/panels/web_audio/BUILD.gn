import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_module.gni")
import("../../../scripts/build/ninja/generate_css.gni")
import("../visibility.gni")

generate_css("css_files") {
  sources = [
    "audioContextSelector.css",
    "webAudio.css",
  ]
}

citizennotes_module("web_audio") {
  sources = [
    "AudioContextContentBuilder.ts",
    "AudioContextSelector.ts",
    "WebAudioModel.ts",
    "WebAudioView.ts",
  ]

  deps = [
    "../../core/common:bundle",
    "../../core/i18n:bundle",
    "../../core/platform:bundle",
    "../../core/sdk:bundle",
    "../../generated:protocol",
    "../../ui/legacy:bundle",
    "graph_visualizer:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "web_audio.ts"

  deps = [
    ":css_files",
    ":web_audio",
  ]

  visibility = [
    ":*",
    "../../../test/unittests/front_end/entrypoints/missing_entrypoints/*",
    "../../entrypoints/*",
  ]

  visibility += citizennotes_panels_visibility
}

citizennotes_entrypoint("meta") {
  entrypoint = "web_audio-meta.ts"

  deps = [ ":bundle" ]

  visibility = [ "../../entrypoints/*" ]
}
