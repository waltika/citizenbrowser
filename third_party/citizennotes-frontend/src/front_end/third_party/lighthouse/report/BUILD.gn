import("../../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../../scripts/build/ninja/citizennotes_pre_built.gni")
import("../../visibility.gni")

citizennotes_pre_built("bundle") {
  sources_are_release = false

  sources = [
    "bundle-tsconfig.json",
    "bundle.d.ts",
    "bundle.js",
  ]
}

citizennotes_entrypoint("report") {
  entrypoint = "report.ts"

  deps = [ ":bundle" ]
  visibility = [
    "../*",
    "../../../panels/lighthouse/*",
  ]
}
