import("../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../scripts/build/ninja/citizennotes_pre_built.gni")
import("../visibility.gni")

citizennotes_pre_built("wasmparser") {
  sources_are_release = false

  sources = [
    "package/dist/esm/WasmDis.d.ts",
    "package/dist/esm/WasmDis.js",
    "package/dist/esm/WasmParser.d.ts",
    "package/dist/esm/WasmParser.js",
    "wasmparser-tsconfig.json",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "wasmparser.ts"

  deps = [ ":wasmparser" ]

  visibility = [ "../../entrypoints/wasmparser_worker/*" ]

  visibility += citizennotes_third_party_visibility
}
