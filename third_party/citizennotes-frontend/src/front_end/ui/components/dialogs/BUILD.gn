import("../../../../scripts/build/ninja/citizennotes_entrypoint.gni")
import("../../../../scripts/build/ninja/citizennotes_module.gni")
import("../../../../scripts/build/ninja/generate_css.gni")

generate_css("css_files") {
  sources = [
    "dialog.css",
    "iconDialog.css",
    "shortcutDialog.css",
  ]
}

citizennotes_module("dialogs") {
  sources = [
    "Dialog.ts",
    "IconDialog.ts",
    "ShortcutDialog.ts",
  ]
  deps = [
    "../../../../front_end/core/platform:bundle",
    "../../../../front_end/services/window_bounds:bundle",
    "../../../../front_end/ui/components/buttons:bundle",
    "../../../../front_end/ui/components/helpers:bundle",
    "../../../../front_end/ui/components/render_coordinator:bundle",
  ]
}

citizennotes_entrypoint("bundle") {
  entrypoint = "dialogs.ts"

  deps = [
    ":css_files",
    ":dialogs",
  ]

  visibility = [ "*" ]
}
